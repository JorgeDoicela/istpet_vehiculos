# ============================================================
# ISTPET Logística — Configuración SERVIDOR INSTITUCIONAL
# Servidor: 192.168.7.50 (red interna ISTPET)
# ============================================================

# ─── ENTORNO ────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ─── BD LOCAL (istpet_vehiculos) ────────────────────────────
LOCAL_DB_HOST=db
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=istpet_vehiculos
LOCAL_DB_USER=root
LOCAL_DB_PASS=zenith_root_2026

# ─── BD SIGAFI (solo lectura) ───────────────────────────────
REMOTE_SIGAFI_SERVER=192.168.7.50
REMOTE_SIGAFI_PORT=3307
REMOTE_SIGAFI_DB=sigafi_es
REMOTE_SIGAFI_USER=root
REMOTE_SIGAFI_PASS=rootpass57

# ─── JWT ────────────────────────────────────────────────────
JWT_KEY=ISTPET_ZENITH_ULTRA_SECURE_KEY_2026_PROD_CAMBIAR_EN_PROD

# ─── CORS ───────────────────────────────────────────────────
# Cambiar a la IP o dominio real donde se sirva el frontend.
CORS_ALLOWED_ORIGINS=http://192.168.7.50,http://192.168.7.50:80,http://localhost:5173

# ─── FRONTEND ───────────────────────────────────────────────
VITE_API_URL=http://192.168.7.50:5112/api

# ─── SINCRONIZACIÓN SIGAFI ──────────────────────────────────
SIGAFI_SYNC_ENABLED=true
SIGAFI_SYNC_INTERVAL=15

# ─── PUERTOS DOCKER ─────────────────────────────────────────
BACKEND_PORT=5112
FRONTEND_PORT=80
