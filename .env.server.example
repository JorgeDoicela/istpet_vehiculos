ASPNETCORE_ENVIRONMENT=Production
DATABASE_MODE=Direct

# BD operativa (istpet_vehiculos) - existe en el servidor
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=istpet_vehiculos
LOCAL_DB_USER=root
LOCAL_DB_PASS=CAMBIAR_ESTO

# BD SIGAFI - existe en el servidor
REMOTE_SIGAFI_SERVER=127.0.0.1
REMOTE_SIGAFI_PORT=3307
REMOTE_SIGAFI_DB=sigafi_es
REMOTE_SIGAFI_USER=root
REMOTE_SIGAFI_PASS=CAMBIAR_ESTO

JWT_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_LARGA_MINIMO_32_CHARS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:58080

# En modo Direct normalmente desactivado
SIGAFI_SYNC_ENABLED=false
SIGAFI_SYNC_INTERVAL=15

BACKEND_PORT=55112
FRONTEND_PORT=58080
