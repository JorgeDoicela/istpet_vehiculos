# ============================================================
# ISTPET Logística — Variables de entorno
# Copiar este archivo a ".env" y rellenar con valores reales.
# NUNCA commitear el .env real con credenciales.
# Generar JWT_KEY: openssl rand -base64 48
# ============================================================

# ─── ENTORNO ────────────────────────────────────────────────
# Development → habilita Swagger y CORS abierto
# Production  → deshabilita Swagger y aplica CORS restrictivo
ASPNETCORE_ENVIRONMENT=Production

# ─── BD LOCAL (istpet_vehiculos) ────────────────────────────
LOCAL_DB_HOST=db          # "db" si usas docker-compose, IP si es externo
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=istpet_vehiculos
LOCAL_DB_USER=root
LOCAL_DB_PASS=CAMBIAR_ESTO

# ─── BD SIGAFI (solo lectura) ───────────────────────────────
REMOTE_SIGAFI_SERVER=IP_DEL_SERVIDOR_SIGAFI
REMOTE_SIGAFI_PORT=3306
REMOTE_SIGAFI_DB=sigafi_es
REMOTE_SIGAFI_USER=usuario_sigafi
REMOTE_SIGAFI_PASS=CAMBIAR_ESTO

# ─── JWT ────────────────────────────────────────────────────
# Mínimo 32 caracteres, único por entorno, NUNCA compartir.
JWT_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_LARGA_MINIMO_32_CHARS

# ─── CORS ───────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios).
# En producción poner solo el dominio real del frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── FRONTEND ───────────────────────────────────────────────
# URL completa a /api de la API en producción.
VITE_API_URL=http://localhost:5112/api

# ─── SINCRONIZACIÓN SIGAFI ──────────────────────────────────
# false = desactiva el sync automático (útil si SIGAFI no es alcanzable).
SIGAFI_SYNC_ENABLED=true
SIGAFI_SYNC_INTERVAL=15

# ─── PUERTOS DOCKER (opcional, cambiar si hay conflicto) ────
BACKEND_PORT=5112
FRONTEND_PORT=80
