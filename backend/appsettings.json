{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "SigafiMirrorSync": {
        "Enabled": true,
        "IntervalMinutes": 15,
        "RunOnStartup": true,
        "StartupDelaySeconds": 30
    },

    "DatabaseSettings": {
        "Database_Mode": "Mirror" 
    },

    "ConnectionStrings": {
        "DefaultConnection": "",
        "SigafiConnection": "",
        "CentralDbName": "sigafi_es"
    },

    "JwtSettings": {
        "Key": "",
        "Issuer": "ISTPET_Zenith",
        "Audience": "ISTPET_Logistics_App",
        "ExpiryInMinutes": 480
    },

    "Cors": {
        "AllowedOrigins": []
    },

    "RateLimiting": {
        "LoginPermitLimit": 10,
        "LoginWindowSeconds": 30
    }
}
